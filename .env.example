# --- Twilio (sandbox / trial) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# SMS: your Twilio trial phone number in E.164 (US number for the sandbox)
TWILIO_SMS_FROM=+15005550006

# --- Node SMS sender (src/messaging) ---
# The "from" number the Node TwilioSmsSender uses (same Twilio number as above).
TWILIO_PHONE_NUMBER=
# Your own phone in E.164 (e.g. +15551234567) to receive the test messages.
TEST_TO_NUMBER=

# WhatsApp: the Twilio WhatsApp sandbox number (default is +14155238886)
TWILIO_WHATSAPP_FROM=+14155238886

# WhatsApp sandbox: a plain-text body is fine. In production this must be an
# approved template. Leave the SID blank while using the sandbox.
TWILIO_WHATSAPP_TEMPLATE_SID=

# Public base URL Twilio will call back for delivery status.
# In local dev this is your ngrok/tunnel URL, e.g. https://abc123.ngrok.io
PUBLIC_BASE_URL=http://localhost:8000

# Shared secret CloudCannon sends so we can verify the webhook is really from CC.
CLOUDCANNON_WEBHOOK_SECRET=change-me

# Skip real Twilio calls and just log what *would* be sent. Great for first runs.
DRY_RUN=true

# SQLite path
DATABASE_PATH=data/stevie.db

# Quiet hours (local recipient time). Sends outside this window are deferred.
QUIET_HOURS_START=9    # 9am
QUIET_HOURS_END=21     # 9pm
