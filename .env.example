# --- Twilio (sandbox / trial) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# SMS: your Twilio trial phone number in E.164 (US number for the sandbox)
TWILIO_SMS_FROM=+15005550006

# --- Node SMS sender (src/messaging) ---
# The "from" number the Node TwilioSmsSender uses (same Twilio number as above).
TWILIO_PHONE_NUMBER=
# Your own phone in E.164 (e.g. +15551234567) to receive the test messages.
TEST_TO_NUMBER=
# A second test recipient (Anirudh) in E.164. Leave blank to skip.
ANIRUDH_TO_NUMBER=

# --- WhatsApp via Meta Cloud API (src/messaging/whatsAppSender.js) ---
# From the Meta App -> WhatsApp -> API Setup page.
WHATSAPP_PHONE_NUMBER_ID=421479604375270
WHATSAPP_ACCESS_TOKEN=paste_the_generated_token_here
WHATSAPP_WABA_ID=411161885409381
# Your own WhatsApp number in E.164 to receive the test.
WHATSAPP_TEST_TO=+918328697349
# Which approved template to send (hello_world takes no variables).
WHATSAPP_TEMPLATE=hello_world
WHATSAPP_TEMPLATE_LANG=en_US

# Public base URL Twilio will call back for delivery status.
# In local dev this is your ngrok/tunnel URL, e.g. https://abc123.ngrok.io
PUBLIC_BASE_URL=http://localhost:8000

# Skip real Twilio calls and just log what *would* be sent. Great for first runs.
DRY_RUN=true

# SQLite path
DATABASE_PATH=data/stevie.db

# Quiet hours (local recipient time). Sends outside this window are deferred.
QUIET_HOURS_START=9    # 9am
QUIET_HOURS_END=21     # 9pm
